@model EmreCakmakoglu.Models.Book
@{
    Layout = "_Layout";
}
<div class="mb-4">
    <a href="/Admin/Index" class="text-white-50 small hover-red text-decoration-none">
        <i class="bi bi-arrow-left me-2"></i>Panel Ana Sayfasına Dön
    </a>
</div>
<div class="container mt-5 pt-4">
    <div class="card bg-dark text-white p-4 border-secondary shadow">
        <h3>Yeni Kitap Ekle</h3>
        <form asp-action="BookCreate" method="post" enctype="multipart/form-data">
            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label class="form-label">Kitap Adı</label>
                        <input asp-for="Title" class="form-control bg-dark text-white border-secondary" required>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Durum (Örn: Yeni Roman, Çok Yakında)</label>
                            <input asp-for="Subtitle" class="form-control bg-dark text-white border-secondary">
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Satın Alma Linki (Opsiyonel)</label>
                        <input asp-for="BuyLink" class="form-control bg-dark text-white border-secondary" placeholder="https://...">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Kapak Görseli</label>
                            <input type="file" name="imageFile" class="form-control bg-dark text-white border-secondary">
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Kitap Özeti / Tanıtım</label>
                            <textarea asp-for="Description" id="bookEditor"></textarea>
                        </div>

                        <button type="submit" class="btn btn-danger w-100 fw-bold">KİTABI KAYDET</button>
                    </form>
                </div>
            </div>

            <script src="https://cdn.ckeditor.com/ckeditor5/41.1.0/classic/ckeditor.js"></script>
            <script>
                ClassicEditor.create(document.querySelector('#bookEditor')).catch(error => { console.error(error); });
            </script>
            <style>    .ck-editor__editable {
                min-height: 300px;
                color: #000 !important;
                }</style>