@model EmreCakmakoglu.Models.Album
@{
    Layout = "_Layout";
    ViewData["Title"] = "Yeni Albüm Oluştur";
}

<div class="container" style="margin-top: 150px; margin-bottom: 100px;">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="section-glass-panel p-5 shadow-lg">
                <h2 class="text-white mb-4 playfair">Yeni Albüm Oluştur</h2>
                <div class="red-line-start mb-5" style="width: 50px; height: 3px; background: #8B261D;"></div>

                <form asp-action="AlbumCreate" method="post" enctype="multipart/form-data">
                    <div class="mb-4">
                        <label class="form-label text-white-50 small letter-spacing-2">ALBÜM ADI</label>
                        <input type="text" name="Title" class="form-control admin-glass-input" placeholder="Örn: Konser Hatıraları" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-white-50 small letter-spacing-2">KISA AÇIKLAMA</label>
                        <textarea name="Description" class="form-control admin-glass-input" rows="3" placeholder="Albüm hakkında kısa bir bilgi..." required></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-white-50 small letter-spacing-2">ALBÜM KAPAĞI</label>
                        <input type="file" name="coverImage" class="form-control admin-glass-input" accept="image/*" required>
                        <small class="text-info mt-2 d-block" style="font-size: 0.75rem; opacity: 0.8;">
                            <i class="bi bi-info-circle me-1"></i> Bu fotoğraf galeri listesinde kapak olarak görünecek.
                        </small>
                    </div>

                    <div class="d-flex gap-3 mt-5">
                        <button type="submit" class="btn btn-danger px-5 py-2 fw-bold letter-spacing-1">OLUŞTUR</button>
                        <a href="/Admin/AlbumList" class="btn btn-outline-light px-4 py-2 opacity-50 hover-opacity-100">İPTAL</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .playfair { font-family: 'Playfair Display', serif; }
    .letter-spacing-2 { letter-spacing: 2px; }
    
    /* Admin Paneline Özel Input Stili */
    .admin-glass-input {
        background: rgba(255, 255, 255, 0.05) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: white !important;
        padding: 12px 15px;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .admin-glass-input:focus {
        background: rgba(255, 255, 255, 0.1) !important;
        border-color: #ff4d4d !important;
        box-shadow: 0 0 10px rgba(255, 77, 77, 0.2);
        outline: none;
    }

    /* Dosya seçme butonunun rengini düzeltme */
    .admin-glass-input::file-selector-button {
        background: rgba(255, 255, 255, 0.1);
        color: white;
        border: none;
        padding: 5px 15px;
        border-radius: 4px;
        margin-right: 15px;
        cursor: pointer;
    }

    .admin-glass-input::file-selector-button:hover {
        background: rgba(255, 255, 255, 0.2);
    }

    .hover-opacity-100:hover { opacity: 1 !important; }
</style>