@model EmreCakmakoglu.Models.Book
@{
    Layout = "_Layout";
}
<div class="mb-4">
    <a href="/Admin/Index" class="text-white-50 small hover-red text-decoration-none">
        <i class="bi bi-arrow-left me-2"></i>Panel Ana Sayfasına Dön
    </a>
</div>
<div class="container mt-5 pt-4">
    <div class="card bg-dark text-white p-4 border-secondary shadow">
        <div class="d-flex justify-content-between mb-4">
            <h3>Kitap Düzenle: @Model.Title</h3>
            <a href="/Admin/BookList" class="btn btn-outline-secondary btn-sm">Listeye Dön</a>
        </div>

        <form asp-action="BookEdit" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImageUrl" />

            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label class="form-label">Kitap Adı</label>
                        <input asp-for="Title" class="form-control bg-dark text-white border-secondary" required>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">Alt Başlık / Durum</label>
                            <input asp-for="Subtitle" class="form-control bg-dark text-white border-secondary">
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Satın Alma Linki</label>
                        <input asp-for="BuyLink" class="form-control bg-dark text-white border-secondary">
                        </div>

                        <div class="mb-3">
                            <label class="form-label d-block">Mevcut Kapak</label>
                            <img src="@Model.ImageUrl" class="img-thumbnail mb-2" style="height: 120px; object-fit: cover;">
                            <input type="file" name="imageFile" class="form-control bg-dark text-white border-secondary">
                            <small class="text-muted">Değiştirmek istemiyorsanız boş bırakın.</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Kitap Özeti</label>
                            <textarea asp-for="Description" id="bookEditEditor"></textarea>
                        </div>

                        <button type="submit" class="btn btn-warning w-100 fw-bold text-dark">DEĞİŞİKLİKLERİ KAYDET</button>
                    </form>
                </div>
            </div>

            <script src="https://cdn.ckeditor.com/ckeditor5/41.1.0/classic/ckeditor.js"></script>
            <script>
                ClassicEditor.create(document.querySelector('#bookEditEditor')).catch(error => { console.error(error); });
            </script>
            <style>    .ck-editor__editable {
                min-height: 300px;
                color: #000 !important;
                }</style>