@model IEnumerable<EmreCakmakoglu.Models.ContactMessage>
@{
    Layout = "_Layout"; // Senin admin layout ismin neyse
    ViewData["Title"] = "Gelen Mesajlar";
}
<div class="mb-4">
    <a href="/Admin/Index" class="text-white-50 small hover-red text-decoration-none">
        <i class="bi bi-arrow-left me-2"></i>Panel Ana Sayfasına Dön
    </a>
</div>
<div class="card bg-dark text-white border-secondary shadow">
    <div class="card-header border-secondary d-flex justify-content-between align-items-center">
        <h5 class="mb-0 italic">Gelen Mesajlar</h5>
        <span class="badge bg-danger">@Model.Count(m => !m.IsRead) Yeni Mesaj</span>
    </div>
    <div class="card-body p-0">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr class="text-secondary small">
                    <th class="ps-4">DURUM</th>
                    <th>GÖNDEREN</th>
                    <th>KONU</th>
                    <th>TARİH</th>
                    <th class="text-end pe-4">İŞLEM</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr style="@(m.IsRead ? "opacity: 0.6;" : "font-weight: bold;")">
                        <td class="ps-4">
                            @if (m.IsRead)
                            {
                                <i class="bi bi-envelope-open text-muted"></i>
                            }
                            else
                            {

                                <i class="bi bi-envelope-fill text-danger"></i>
                            }
                        </td>
                        <td>@m.FullName <br><small class="text-muted">@m.Email</small></td>
                        <td>@m.Subject</td>
                        <td>@m.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="text-end pe-4">
                            <a href="@Url.Action("MessageDetail", "Admin", new { id = m.Id })" class="btn btn-sm btn-outline-info me-2">Oku</a>
                            <form asp-action="DeleteMessage" asp-route-id="@m.Id" method="post" class="d-inline" onsubmit="return confirm('Silmek istediğine emin misin?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>