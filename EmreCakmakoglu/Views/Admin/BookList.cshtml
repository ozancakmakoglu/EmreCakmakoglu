@model IEnumerable<EmreCakmakoglu.Models.Book>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Kitap Yönetimi";
}

<div class="mb-4">
    <a href="/Admin/Index" class="text-white-50 small hover-red text-decoration-none">
        <i class="bi bi-arrow-left me-2"></i>Panel Ana Sayfasına Dön
    </a>
</div>

<div class="container mt-5 pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-white border-start border-danger border-4 ps-3">Kitap Yönetimi</h2>
            <p class="text-white-50 small m-0">Yayınlanmış veya çıkacak kitapları buradan yönetin.</p>
        </div>
        <a href="/Admin/BookCreate" class="btn btn-danger shadow-sm px-4 rounded-pill">
            <i class="bi bi-plus-lg me-2"></i>Yeni Kitap Ekle
        </a>
    </div>

    <div class="card bg-dark border-secondary shadow-lg">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead>
                    <tr class="text-secondary small text-uppercase">
                        <th class="ps-4" style="width: 100px;">Kapak</th>
                        <th>Kitap Adı</th>
                        <th>Alt Başlık / Durum</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="border-bottom border-white-5">
                                <td class="ps-4 py-3">
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/roman-kapak.jpg" : item.ImageUrl)"
                                         class="rounded shadow-sm" 
                                         style="width:50px; height:70px; object-fit:cover; border: 1px solid #333;">
                                </td>
                                <td class="fw-bold text-white">@item.Title</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Subtitle))
                                    {
                                        <span class="badge bg-secondary opacity-75">@item.Subtitle</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        @* DÜZENLEME BUTONU (Link olarak) *@
                                        <a href="/Admin/BookEdit/@item.Id" class="btn btn-sm btn-outline-warning rounded-pill px-3">
                                            <i class="bi bi-pencil me-1"></i> Düzenle
                                        </a>

                                        @* SİLME FORMU *@
                                        <form asp-action="BookDelete" asp-route-id="@item.Id" method="post"
                                              onsubmit="return confirm('Bu kitabı silmek istediğinize emin misiniz?')"
                                              style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                                <i class="bi bi-trash me-1"></i> Sil
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted fst-italic">Henüz kitap eklenmemiş.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .hover-red:hover {
        color: #dc3545 !important;
        transition: 0.3s;
    }
    .border-white-5 { border-color: rgba(255, 255, 255, 0.05) !important; }
    .table-hover tbody tr:hover {
        background-color: rgba(255, 255, 255, 0.02) !important;
        transition: 0.3s;
    }
</style>