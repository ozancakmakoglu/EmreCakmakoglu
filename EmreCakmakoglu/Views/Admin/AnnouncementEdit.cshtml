@model EmreCakmakoglu.Models.Announcement
@{
    Layout = "_Layout";
    ViewData["Title"] = "Duyuru Düzenle";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="d-flex align-items-center mb-4">
                <a href="/Admin/AnnouncementList" class="btn btn-outline-light btn-sm rounded-circle me-3">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h2 class="text-white m-0">DUYURU DÜZENLE</h2>
            </div>

            <div class="p-4 p-md-5 bg-dark border border-secondary rounded-4 shadow-lg">
                <form asp-action="AnnouncementEdit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="row">
                        <div class="col-md-4 mb-4">
                            <label class="form-label text-white-50 small fw-bold">TARİH METNİ</label>
                            <input asp-for="DateText" class="form-control bg-black text-white border-secondary p-3" placeholder="Örn: 20 Nisan" />
                        </div>
                        <div class="col-md-8 mb-4">
                            <label class="form-label text-white-50 small fw-bold">DUYURU BAŞLIĞI</label>
                            <input asp-for="Title" class="form-control bg-black text-white border-secondary p-3" required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-white-50 small fw-bold">ALT BAŞLIK (OPSİYONEL)</label>
                        <input asp-for="SubTitle" class="form-control bg-black text-white border-secondary p-3" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-white-50 small fw-bold">YÖNLENDİRME ADRESİ (URL)</label>
                        <input asp-for="Url" class="form-control bg-black text-white border-secondary p-3" placeholder="http://..." />
                        <div class="form-text text-muted">Duyuruya tıklandığında gidilecek adres.</div>
                    </div>



                    <div class="d-grid mt-5">
                        <button type="submit" class="btn btn-danger btn-lg rounded-pill p-3 fw-bold shadow">
                            DEĞİŞİKLİKLERİ KAYDET
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>