@{
    Layout = "_Layout";
    ViewData["Title"] = "Yönetim Paneli";
}

<div class="container-fluid">
    <div class="row g-4">
        @* 1. DİSKOGRAFİ YÖNETİMİ *@
        <div class="col-md-4">
            <div class="admin-card text-center p-5 shadow-lg">
                <i class="bi bi-music-note-beamed display-3 text-danger mb-3"></i>
                <h4 class="text-white mb-4">DİSKOGRAFİ</h4>
                <p class="text-white-50 small mb-4">Müzik eserlerini ekle, düzenle veya kaldır.</p>
                <a href="/Admin/MusicList" class="btn btn-outline-danger w-100 py-2">YÖNET</a>
            </div>
        </div>

        @* 2. BLOG YÖNETİMİ *@
        <div class="col-md-4">
            <div class="admin-card text-center p-5 shadow-lg">
                <i class="bi bi-journal-text display-3 text-danger mb-3"></i>
                <h4 class="text-white mb-4">BLOG YAZILARI</h4>
                <p class="text-white-50 small mb-4">Yazılarını ve makalelerini buradan yönet.</p>
                <a href="/Admin/BlogList" class="btn btn-outline-danger w-100 py-2">YÖNET</a>
            </div>
        </div>

        @* 3. GALERİ YÖNETİMİ (Eski Mesajlar yerine gelen yeni kısım) *@
        <div class="col-md-4">
            <div class="admin-card text-center p-5 shadow-lg border-danger border-opacity-25">
                <i class="bi bi-images display-3 text-danger mb-3"></i>
                <h4 class="text-white mb-4">FOTO GALERİ</h4>
                <p class="text-white-50 small mb-4">Fotoğraf albümleri oluştur ve anılarını paylaş.</p>
                <a href="/Admin/AlbumList" class="btn btn-danger w-100 py-2">ALBÜMLERİ YÖNET</a>
            </div>
        </div>

        @* 4. KİTAP YÖNETİMİ *@
        <div class="col-md-4">
            <div class="admin-card text-center p-5 shadow-lg">
                <i class="bi bi-book display-3 text-danger mb-3"></i>
                <h4 class="text-white mb-4">KİTAPLAR</h4>
                <p class="text-white-50 small mb-4">Yayınlanmış kitaplarını sisteme ekle.</p>
                <a href="/Admin/BookList" class="btn btn-outline-danger w-100 py-2">YÖNET</a>
            </div>
        </div>
        @* 5. MENÜ YÖNETİMİ *@
<div class="col-md-4">
    <div class="admin-card text-center p-5 shadow-lg">
        <i class="bi bi-list-ul display-3 text-danger mb-3"></i>
        <h4 class="text-white mb-4">MENÜ YÖNETİMİ</h4>
        <p class="text-white-50 small mb-4">Üst menüdeki başlıkları ve sıralamayı düzenle.</p>
        <a href="/Admin/MenuList" class="btn btn-outline-danger w-100 py-2">DÜZENLE</a>
    </div>
</div>
        @* 6. SİTE AYARLARI *@
        <div class="col-md-4">
            <div class="admin-card text-center p-5 shadow-lg">
                <i class="bi bi-gear display-3 text-danger mb-3"></i>
                <h4 class="text-white mb-4">SİTE AYARLARI</h4>
                <p class="text-white-50 small mb-4">Sosyal medya linkleri, tema ve hero görseli.</p>
                <a href="/Admin/Settings" class="btn btn-outline-danger w-100 py-2">DÜZENLE</a>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 20px;
        transition: all 0.4s ease;
    }
    .admin-card:hover {
        background: rgba(139, 38, 29, 0.05);
        border-color: rgba(139, 38, 29, 0.3);
        transform: translateY(-10px);
    }
</style>