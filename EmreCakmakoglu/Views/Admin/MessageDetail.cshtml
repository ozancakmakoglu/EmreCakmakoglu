@model EmreCakmakoglu.Models.ContactMessage
@{
    ViewData["Title"] = "Mesaj Detayı";
    Layout = "_Layout"; // Veya admin için kullandığın layout adı
}
<div class="mb-4">
    <a href="/Admin/Index" class="text-white-50 small hover-red text-decoration-none">
        <i class="bi bi-arrow-left me-2"></i>Panel Ana Sayfasına Dön
    </a>
</div>
<div class="container" style="margin-top: 120px; margin-bottom: 100px;">
    <div class="row justify-content-center">
        <div class="col-lg-8 section-glass-panel shadow-lg">
            
            @* Üst Bilgi *@
            <div class="d-flex justify-content-between align-items-start border-bottom border-secondary border-opacity-25 pb-4 mb-4">
                <div>
                    <h3 class="section-title mb-1">MESAJ DETAYI</h3>
                    <p class="text-white-50 small mb-0">
                        <i class="bi bi-calendar3 me-2"></i> @Model.CreatedDate.ToString("dd MMMM yyyy HH:mm")
                    </p>
                </div>
                <a href="/Admin/Messages" class="btn btn-custom-outline btn-sm">Listeye Dön</a>
            </div>

            @* Gönderen Bilgileri *@
            <div class="row g-4 mb-5">
                <div class="col-md-6">
                    <label class="text-danger small letter-spacing-2 mb-1">GÖNDEREN</label>
                    <div class="fs-5 text-white">@Model.FullName</div>
                </div>
                <div class="col-md-6 text-md-end">
                    <label class="text-danger small letter-spacing-2 mb-1">E-POSTA</label>
                    <div class="fs-5 text-white">
                        <a href="mailto:@Model.Email" class="text-white text-decoration-underline">@Model.Email</a>
                    </div>
                </div>
            </div>

            @* Mesaj İçeriği *@
            <div class="message-content p-4" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); min-height: 200px;">
                <label class="text-danger small letter-spacing-2 mb-3 d-block">KONU: @Model.Subject</label>
                <div class="text-white-50 italic" style="white-space: pre-line; line-height: 1.8;">
                    @Model.MessageBody
                </div>
            </div>

            @* İşlem Butonları *@
            <div class="mt-5 d-flex gap-3 justify-content-end">
                <form asp-action="DeleteMessage" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Bu mesajı kalıcı olarak silmek istediğinize emin misiniz?')">
                    <button type="submit" class="btn btn-outline-danger btn-sm px-4">Mesajı Sil</button>
                </form>
                <a href="mailto:@Model.Email?subject=Yanıt: @Model.Subject" class="btn btn-custom-red btn-sm px-4">Cevapla</a>
            </div>

        </div>
    </div>
</div>