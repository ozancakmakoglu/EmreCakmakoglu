@model EmreCakmakoglu.Models.Album
@{
    Layout = "_Layout"; // Hata almamak için ana layout'u kullanıyoruz
    ViewData["Title"] = Model.Title + " - Fotoğraflar";
}

<div class="container" style="margin-top: 120px; margin-bottom: 100px;">
    <div class="section-glass-panel p-5">
        
        @* Başlık ve Geri Dönüş *@
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="text-white mb-0">@Model.Title</h2>
                <p class="text-white-50 small">Bu albümde @Model.Images.Count fotoğraf var.</p>
            </div>
            <a href="/Admin/AlbumList" class="btn btn-outline-light btn-sm px-4">Listeye Dön</a>
        </div>

        @* YENİ FOTOĞRAF EKLEME FORMU *@
        <div class="card bg-dark border-secondary border-opacity-25 mb-5 shadow">
            <div class="card-body p-4">
                <h5 class="text-danger mb-4">Albümü Zenginleştir</h5>
                <form asp-action="AddImageToAlbum" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="AlbumId" value="@Model.Id" />
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="text-white-50 small mb-2">Fotoğraf Seç</label>
                            <input type="file" name="photo" class="form-control glass-input" required>
                        </div>
                        <div class="col-md-5">
                            <label class="text-white-50 small mb-2">Fotoğraf Altı Notu (Opsiyonel)</label>
                            <input type="text" name="Caption" class="form-control glass-input" placeholder="Bu anı bir cümleyle anlat...">
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-danger w-100">YÜKLE</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        @* YÜKLENEN FOTOĞRAFLARI GÖRÜNTÜLE *@
        <div class="row g-4">
            <h5 class="text-white-50 mb-3 border-bottom border-secondary pb-2">Yüklenen Görseller</h5>
            @if (!Model.Images.Any())
            {
                <div class="col-12 text-center py-5">
                    <p class="text-white-50 italic">Henüz bu albüme bir fotoğraf eklenmedi.</p>
                </div>
            }
            @foreach (var img in Model.Images)
            {
                <div class="col-6 col-md-3">
                    <div class="gallery-admin-item position-relative shadow-sm rounded overflow-hidden">
                        <img src="@img.ImageUrl" class="img-fluid" style="height: 200px; width: 100%; object-fit: cover;">
                        <div class="bg-black bg-opacity-75 p-2 small text-truncate" title="@img.Caption">
                            @img.Caption
                        </div>
                        @* Silme butonu opsiyonel *@
                        <a href="/Admin/DeleteImage/@img.Id" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1" onclick="return confirm('Silmek istediğine emin misin?')">
                            <i class="bi bi-x"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .glass-input { background: rgba(255,255,255,0.05) !important; border: 1px solid rgba(255,255,255,0.1) !important; color: white !important; }
    .gallery-admin-item { border: 1px solid rgba(255,255,255,0.1); transition: 0.3s; }
    .gallery-admin-item:hover { transform: scale(1.02); border-color: #ff4d4d; }
</style>