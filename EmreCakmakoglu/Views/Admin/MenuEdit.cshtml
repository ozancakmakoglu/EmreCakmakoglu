@model EmreCakmakoglu.Models.Menu

<div class="container mt-5">
    <h2>Menü Düzenle</h2>
    <hr />
    <form asp-action="MenuEdit" method="post">
        @* ID gizli bir şekilde formda durmalı ki hangi kaydı güncellediğimizi bilelim *@
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label class="form-label">Menü Başlığı</label>
            <input asp-for="Title" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Bağlantı Adresi (Url)</label>
            <input asp-for="Url" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Sıralama</label>
            <input asp-for="Order" type="number" class="form-control" />
        </div>

        <div class="mb-3">
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActive">
                    <label class="form-check-label" for="isActive">
                        Aktif mi?
                    </label>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Değişiklikleri Kaydet</button>
                <a asp-action="MenuList" class="btn btn-secondary">İptal</a>
            </div>
        </form>
    </div>