@model IEnumerable<EmreCakmakoglu.Models.Announcement>

<div class="ann-list-container">
    @foreach (var item in Model)
    {
        <div class="ann-row">
            @if (!string.IsNullOrEmpty(item.Url))
            {
                <a href="@item.Url" class="ann-full-link" target="_blank">
                    <span class="ann-date">@item.DateText</span>
                    <div class="ann-content">
                        <span class="ann-title">@item.Title</span>
                        @if (!string.IsNullOrEmpty(item.SubTitle))
                        {
                            <span class="ann-sub">@item.SubTitle</span>
                        }
                    </div>
                    <i class="bi bi-arrow-right-short ann-icon"></i>
                </a>
            }
            else
            {
                <div class="ann-full-link no-click">
                    <span class="ann-date">@item.DateText</span>
                    <div class="ann-content">
                        <span class="ann-title">@item.Title</span>
                        @if (!string.IsNullOrEmpty(item.SubTitle))
                        {
                            <span class="ann-sub">@item.SubTitle</span>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>