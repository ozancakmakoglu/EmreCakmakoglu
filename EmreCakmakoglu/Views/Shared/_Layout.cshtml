@using EmreCakmakoglu.Data
@inject AppDbContext _context
@{
    // Veritabanından mevcut ayarları çekiyoruz
    var settings = _context.SiteSettings.FirstOrDefault();
    // Eğer veritabanında bir tema seçili değilse varsayılan olarak "site.css" kullanıyoruz
    var activeTheme = settings?.ActiveTheme ?? "site.css";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Emre Çakmakoğlu</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    @* DİNAMİK TEMA YÜKLEYİCİ: Veritabanındaki değere göre site.css, site2.css vb. yüklenir *@
    <link rel="stylesheet" href="~/css/@activeTheme" asp-append-version="true" />
</head>
<body class="bg-dark text-light">

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-transparent py-4">
            <div class="container">
                <a class="navbar-brand logo-text" href="/">emrecakmakoglu.com.tr</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            @* Tüm Müzikler Sayfası *@
                            <a class="nav-link" asp-controller="Home" asp-action="Music">Müzik</a>
                        </li>
                        <li class="nav-item">
                            @* Tüm Kitaplar Sayfası *@
                            <a class="nav-link" asp-controller="Home" asp-action="Books">Kitap</a>
                        </li>
                        <li class="nav-item">
                            @* Tüm Blog Yazıları Sayfası *@
                            <a class="nav-link" asp-controller="Home" asp-action="Blog">Blog</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Contact">İletişim</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="py-5 text-center border-top border-secondary mt-5">
        <div class="container">
            <p>&copy; 2026 - Emre Çakmakoğlu</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>