@model EmreCakmakoglu.Models.Book
@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5 pt-5">
    <div class="row g-5">
        <div class="col-md-4">
            <img src="@Model.ImageUrl" class="img-fluid shadow-lg rounded" alt="@Model.Title">
        </div>
        <div class="col-md-8">
            <h1 class="display-4 text-white playfair">@Model.Title</h1>
            <p class="text-danger fw-bold text-uppercase letter-spacing-2">@Model.Subtitle</p>
            <hr class="border-secondary opacity-25 my-4">
            
            <div class="text-white-50 fs-5 leading-relaxed">
                @Html.Raw(Model.Description)
            </div>

            @if (!string.IsNullOrEmpty(Model.BuyLink))
            {
                <a href="@Model.BuyLink" target="_blank" class="btn btn-custom-red btn-lg mt-5">KİTABI SATIN AL</a>
            }
            <br>
            <a href="/" class="btn btn-link text-muted mt-3 p-0 text-decoration-none">← Ana Sayfaya Dön</a>
        </div>
    </div>
</div>