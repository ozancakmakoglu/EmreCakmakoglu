@model EmreCakmakoglu.Models.Album
@{
    ViewData["Title"] = Model.Title;
}

@* Fotoğrafları büyütmek için gereken kütüphane (Fancybox) *@
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@fancyapps/ui@5.0/dist/fancybox/fancybox.css" />

<div class="container" style="margin-top: 50px; margin-bottom: 100px;">
    <div class="mb-5">
        <a href="/Home/Gallery" class="text-white-50 text-decoration-none small mb-3 d-inline-block">
            <i class="bi bi-arrow-left me-1"></i> GALERİYE DÖN
        </a>
        <h1 class="display-4 text-white playfair">@Model.Title</h1>
        <p class="text-white-50 fs-5">@Model.Description</p>
        <div class="red-line-start" style="width: 60px; height: 3px; background: #8B261D;"></div>
    </div>

    <div class="row g-4">
        @foreach (var img in Model.Images)
        {
            <div class="col-md-4 col-6">
                <a href="@img.ImageUrl" data-fancybox="gallery" data-caption="@img.Caption">
                    <div class="gallery-item-wrapper shadow-lg">
                        <img src="@img.ImageUrl" class="img-fluid rounded-3" alt="@img.Caption">
                        @if (!string.IsNullOrEmpty(img.Caption))
                        {
                            <div class="img-caption-overlay">@img.Caption</div>
                        }
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@@fancyapps/ui@5.0/dist/fancybox/fancybox.umd.js"></script>
<script>
    Fancybox.bind("[data-fancybox='gallery']", {
        // İsteğe bağlı ayarlar buraya
    });
</script>

<style>
    .gallery-item-wrapper {
        position: relative; overflow: hidden; border-radius: 12px;
        cursor: pointer; aspect-ratio: 1/1;
    }
    .gallery-item-wrapper img {
        width: 100%; height: 100%; object-fit: cover;
        transition: 0.5s;
    }
    .img-caption-overlay {
        position: absolute; bottom: 0; left: 0; width: 100%;
        background: linear-gradient(transparent, rgba(0,0,0,0.8));
        color: white; padding: 15px; font-size: 0.9rem;
        opacity: 0; transition: 0.3s;
    }
    .gallery-item-wrapper:hover img { transform: scale(1.1); }
    .gallery-item-wrapper:hover .img-caption-overlay { opacity: 1; }
</style>