@using EmreCakmakoglu.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext _context
@{
    var settings = _context.SiteSettings.AsNoTracking().FirstOrDefault();
}

<div class="container internal-page-wrapper">
    <div class="text-center">
        <h1 class="page-standard-title">İLETİŞİM</h1>
        <div class="title-separator"></div>
    </div>

    <div class="row justify-content-center mt-5">
        <div class="col-lg-5 col-md-8">
            <div class="contact-glass-card">
                
                @* E-POSTA BÖLÜMÜ *@
                <div class="contact-item">
                    <span class="contact-label">E-POSTA</span>
                    
                    @* Burası boş gelir, botlar hiçbir şey okuyamaz *@
                    <div id="email-placeholder" class="email-secure-wrapper" onclick="revealAndCopy()">
                        <i class="bi bi-shield-lock-fill me-2 opacity-50"></i>
                        <span id="secure-text">E-Posta için tıkla</span>
                    </div>
                    
                    @* Kopyalandı Balonu *@
                    <span class="copy-success" id="copySuccess">Adres Kopyalandı!</span>
                </div>

                <div class="item-divider"></div>

                @* SOSYAL MEDYA *@
                <div class="contact-item">
                    <span class="contact-label">SOSYAL MEDYA</span>
                    <div class="social-links-row">
                        @if (!string.IsNullOrEmpty(settings?.InstagramUrl)) {
                            <a href="@settings.InstagramUrl" target="_blank" class="social-mini-link"><i class="bi bi-instagram"></i></a>
                        }
                        @if (!string.IsNullOrEmpty(settings?.SpotifyArtistUrl)) {
                            <a href="@settings.SpotifyArtistUrl" target="_blank" class="social-mini-link"><i class="bi bi-spotify"></i></a>
                        }
                        @if (!string.IsNullOrEmpty(settings?.YoutubeChannelUrl)) {
                            <a href="@settings.YoutubeChannelUrl" target="_blank" class="social-mini-link"><i class="bi bi-youtube"></i></a>
                        }
                        @if (!string.IsNullOrEmpty(settings?.TwitterUrl)) {
                            <a href="@settings.TwitterUrl" target="_blank" class="social-mini-link"><i class="bi bi-twitter-x"></i></a>
                        }
                    </div>
                </div>
            </div>

            <div class="text-center mt-5">
                <a href="/" class="back-link"><i class="bi bi-arrow-left"></i> ANA SAYFA</a>
            </div>
        </div>
    </div>
</div>

<style>
    .internal-page-wrapper { padding-top: 120px; padding-bottom: 80px; }
    .page-standard-title { font-family: 'Playfair Display', serif; font-size: 3rem; font-weight: 700; color: #fff; letter-spacing: 2px; }
    .title-separator { width: 40px; height: 2px; background: #ff4d4d; margin: 15px auto 40px; }

    .contact-glass-card {
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(25px);
        -webkit-backdrop-filter: blur(25px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 30px;
        padding: 50px 40px;
        text-align: center;
        box-shadow: 0 30px 60px rgba(0,0,0,0.5);
    }

    .contact-label { 
        display: block; font-size: 0.7rem; font-weight: 800; 
        color: rgba(255,255,255,0.4); letter-spacing: 4px; margin-bottom: 20px; 
    }

    /* GÜVENLİ E-POSTA BUTONU */
    .email-secure-wrapper {
        display: inline-flex;
        align-items: center;
        padding: 12px 30px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 100px;
        color: #fff;
        font-family: 'Playfair Display', serif;
        font-size: 1.2rem;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
    }

    .email-secure-wrapper:hover {
        background: rgba(255, 77, 77, 0.1);
        border-color: rgba(255, 77, 77, 0.3);
        transform: translateY(-2px);
    }

    .email-secure-wrapper.revealed {
        background: transparent;
        border-color: transparent;
        cursor: text;
        font-size: 1.5rem;
    }

    /* BAŞARI MESAJI */
    .copy-success {
        display: block; font-size: 0.7rem; color: #ff4d4d; 
        margin-top: 10px; opacity: 0; transition: 0.3s;
    }
    .copy-success.show { opacity: 1; }

    .item-divider { height: 1px; background: rgba(255,255,255,0.05); margin: 30px auto; width: 30%; }

    .social-links-row { display: flex; justify-content: center; gap: 25px; }
    .social-mini-link { font-size: 1.6rem; color: rgba(255,255,255,0.4) !important; transition: 0.3s; }
    .social-mini-link:hover { color: #ff4d4d !important; transform: scale(1.2); }

    .back-link { color: rgba(255,255,255,0.3); text-decoration: none; font-size: 0.75rem; letter-spacing: 2px; }
    .back-link:hover { color: #fff; }
</style>

<script>
    function revealAndCopy() {
        // E-posta parçalanmış halde, botlar bunu birleştiremez
        var p1 = "emrecakmakoglu";
        var p2 = "gmail";
        var p3 = ".com";
        var fullEmail = p1 + "@@" + p2 + p3;

        var wrapper = document.getElementById("email-placeholder");
        var text = document.getElementById("secure-text");
        var success = document.getElementById("copySuccess");

        // 1. Adresi göster
        text.innerText = fullEmail;
        wrapper.classList.add("revealed");
        wrapper.onclick = null; // Tekrar tıklamayı deaktive et

        // 2. Panoya kopyala
        navigator.clipboard.writeText(fullEmail).then(function() {
            success.classList.add("show");
            setTimeout(function() {
                success.classList.remove("show");
            }, 3000);
        });
    }
</script>