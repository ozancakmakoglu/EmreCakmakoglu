@model IEnumerable<EmreCakmakoglu.Models.Music>
@{
    var set = (EmreCakmakoglu.Models.SiteSettings)ViewBag.Settings;
}

@* --- HERO --- *@
<div class="hero-final-wrapper">
    <div class="hero-left-cell">
        <div class="image-center-box">
            <img src="@(set?.HeroImageUrl ?? "/images/ana-gorsel-saydam.png")" class="img-hero-smart">
        </div>
    </div>
    <div class="hero-right-cell">
        <div class="hero-text-container">
            <h1 class="main-title">Emre Çakmakoğlu</h1>
            <div class="announcement-wrapper">
                @await Component.InvokeAsync("Announcement")
            </div>
        </div>
    </div>
</div>

@* --- MÜZİKLER (DİSKOGRAFİ) --- *@
<section id="muzikler" class="container">
    <div class="row justify-content-center">
        <div class="col-lg-11 section-glass-panel">
            <h3 class="section-title">DİSKOGRAFİ</h3>
            <div class="row row-cols-2 row-cols-md-6 g-4 justify-content-center">
                @foreach (var item in Model) {
                    <div class="col text-center">
                        <a href="@Url.Action("MusicDetail", "Home", new { id = item.Id })" class="text-decoration-none">
                            <div class="music-card mb-2"><img src="@item.ImageUrl" class="album-cover"></div>
                            <h6 class="text-white small fw-bold text-truncate">@item.Title</h6>
                            <small class="music-meta">@item.Year - @item.MusicType</small>
                        </a>
                    </div>
                }
            </div>
            <div class="text-center mt-5">
                <a asp-action="Music" class="text-white-50 small letter-spacing-2 text-decoration-none hover-red">— TÜM ARŞİVİ İNCELE —</a>
            </div>
        </div>
    </div>
</section>

@* --- KİTAP & BLOG --- *@
<section id="yazilar" class="container">
    <div class="row justify-content-center">
        <div class="col-lg-11 section-glass-panel">
            <div class="row g-5">
                @* SOL SÜTUN: KİTAP *@
                <div class="col-md-5 v-line text-center d-flex flex-column py-3">
                    <h3 class="section-title text-start mb-4">KİTAP</h3>
                    @if (ViewBag.LatestBook != null) {
                        var book = (EmreCakmakoglu.Models.Book)ViewBag.LatestBook;
                        <div class="book-display-area">
                            <a href="@Url.Action("BookDetail", "Home", new { id = book.Id })" class="book-3d-wrapper">
                                <img src="@book.ImageUrl" class="img-fluid book-3d-main" alt="@book.Title">
                            </a>
                            <h4 class="text-white playfair mt-4 mb-2">@book.Title</h4>
                            <p class="text-white-50 small px-4 mb-4" style="font-style: italic; opacity: 0.6;">@book.Subtitle</p>
                            <a href="@Url.Action("BookDetail", "Home", new { id = book.Id })" class="btn btn-book-premium mt-auto">
                                <span>ESERİ İNCELE</span>
                            </a>
                        </div>
                    }
                </div>

                @* SAĞ SÜTUN: BLOG YAZILARI (İstediğin Yatay Düzen) *@
                <div class="col-md-7">
                    <h3 class="section-title mb-4">BLOG YAZILARI</h3>
                    @foreach (var post in (IEnumerable<EmreCakmakoglu.Models.BlogPost>)ViewBag.Blogs) {
                        var isExternal = !string.IsNullOrEmpty(post.ExternalUrl);
                        var targetUrl = isExternal ? post.ExternalUrl : Url.Action("BlogDetail", "Home", new { id = post.Id });

                        <div class="blog-item-wrapper mb-3">
                            <a href="@targetUrl" target="@(isExternal ? "_blank" : "_self")" class="blog-horizontal-card text-decoration-none">
                                <div class="row g-0 align-items-stretch">
                                    @* SOL: GÖRSEL *@
                                    <div class="col-4 col-lg-3">
                                        <div class="blog-img-box-new h-100">
                                            <img src="@post.ImageUrl" class="img-fluid" alt="@post.Title">
                                        </div>
                                    </div>
                                    @* SAĞ: METİN *@
                                    <div class="col-8 col-lg-9 p-3 d-flex flex-column justify-content-center">
                                        <div class="d-flex justify-content-between align-items-start mb-1">
                                            <h6 class="text-white mb-0 fw-bold blog-title-new text-truncate">@post.Title</h6>
                                            <small class="text-danger opacity-75 font-monospace" style="font-size: 0.65rem;">@post.CreatedDate.ToString("dd.MM.yy")</small>
                                        </div>
                                        <div class="blog-summary-new">@post.Summary</div>
                                        <div class="d-flex align-items-center justify-content-between mt-2">
                                            @if(isExternal) { 
                                                <span class="external-tag-new"><i class="fas fa-link me-1"></i></span>
                                            }
                                            <span class="read-more-tiny">OKU <i class="fas fa-arrow-right ms-1"></i></span>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                    <div class="text-end mt-4">
                        <a asp-action="Blog" class="text-white-50 small letter-spacing-2 text-decoration-none hover-red">TÜM YAZILARI GÖR →</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* --- MEDYA & SOSYAL DUVAR --- *@
<section id="medya" class="container mt-5 mb-5">
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="section-glass-panel h-100 p-4">
                <h3 class="section-title mb-4">ÖNE ÇIKAN VİDEO</h3>
                <div class="ratio ratio-16x9 shadow-lg border border-secondary border-opacity-10">
                    <iframe src="https://www.youtube.com/embed/@(set?.YoutubeVideoId ?? "VqnQmjfkr_4")" allowfullscreen style="border:0;"></iframe>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="section-glass-panel h-100 p-4">
                <h3 class="section-title mb-4">SPOTIFY</h3>
                <iframe src="@(set?.SpotifyEmbedUrl ?? "")" width="100%" height="380" frameBorder="0" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy" style="border-radius:12px;"></iframe>
            </div>
        </div>
    </div>
</section>

<style>
    /* 1. HERO & GENEL */
    .hero-final-wrapper { display: flex; width: 100%; height: 520px; margin-top: -40px; background: transparent; position: relative; overflow: hidden; }
    .hero-left-cell { flex: 0 0 60%; display: flex; align-items: flex-end; justify-content: center; }
    .image-center-box { height: 100%; display: flex; align-items: flex-end; justify-content: center; padding-right: 20px; }
    .img-hero-smart { display: block; height: 100%; width: auto; max-width: 100%; object-fit: contain; object-position: bottom; margin-bottom: -5px; }
    .hero-right-cell { flex: 0 0 40%; display: flex; align-items: center; padding-left: 20px; }
    .main-title { font-family: 'Playfair Display', serif; font-size: 3rem; font-weight: 700; color: #ffffff; margin-bottom: 20px; line-height: 1.1; }
    .announcement-wrapper { border-left: 2px solid rgba(255, 77, 77, 0.4); padding-left: 20px; }
    .hover-red:hover { color: #ff4d4d !important; transition: 0.3s; }

    /* 2. DİSKOGRAFİ */
    .music-meta { font-size: 0.75rem; color: rgba(255, 255, 255, 0.6); text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; display: block; }

    /* 3. KİTAP 3D */
    .book-3d-main { max-width: 220px; border-radius: 4px 12px 12px 4px; box-shadow: 20px 20px 40px rgba(0,0,0,0.6); transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1); transform: perspective(1000px) rotateY(-5deg); }
    .book-3d-wrapper:hover .book-3d-main { transform: perspective(1000px) rotateY(-15deg) translateY(-10px); box-shadow: 30px 30px 60px rgba(0,0,0,0.8); }
    .btn-book-premium { background: transparent; border: 1px solid rgba(255, 77, 77, 0.4); color: #fff; padding: 8px 25px; font-size: 0.75rem; letter-spacing: 2px; transition: all 0.4s; }
    .btn-book-premium:hover { background: #ff4d4d; color: #fff; box-shadow: 0 0 15px rgba(255, 77, 77, 0.4); }

    /* 4. BLOG YATAY KART (SOL GÖRSEL - SAĞ METİN) */
    .blog-horizontal-card { display: block; background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 8px; overflow: hidden; transition: all 0.3s ease; }
    .blog-horizontal-card:hover { background: rgba(255, 77, 77, 0.05); border-color: rgba(255, 77, 77, 0.2); transform: translateX(5px); }
    .blog-img-box-new { overflow: hidden; min-height: 100px; }
    .blog-img-box-new img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }
    .blog-horizontal-card:hover .blog-img-box-new img { transform: scale(1.1); }
    
    .blog-title-new { font-size: 0.95rem; transition: 0.3s; }
    .blog-horizontal-card:hover .blog-title-new { color: #ff4d4d !important; }
    
    .blog-summary-new { font-size: 0.82rem; color: rgba(255,255,255,0.4); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin: 5px 0; }
    .external-tag-new { display: inline-block; font-size: 0.6rem; text-transform: uppercase; background: rgba(255, 77, 77, 0.15); color: #ff4d4d; padding: 1px 7px; border-radius: 3px; font-weight: bold; }
    .read-more-tiny { font-size: 0.65rem; font-weight: bold; color: rgba(255,255,255,0.3); letter-spacing: 1px; }

    /* 5. AYIRICI VE MOBİL */
    .v-line { border-right: 1px solid rgba(255,255,255,0.05); }
    @@media (max-width: 991px) {
        .hero-final-wrapper { flex-direction: column; height: auto; margin-top: 0; padding-top: 80px; }
        .hero-left-cell { height: 400px; }
        .hero-right-cell { text-align: center; padding: 40px 20px; }
        .announcement-wrapper { border-left: none; border-top: 1px solid rgba(255, 77, 77, 0.3); padding-top: 15px; }
    }
    @@media (max-width: 768px) {
        .v-line { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 30px; margin-bottom: 30px; }
    }
</style>