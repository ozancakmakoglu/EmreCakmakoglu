@model IEnumerable<EmreCakmakoglu.Models.Music>
@{
    Layout = "_Layout";
    var set = (EmreCakmakoglu.Models.SiteSettings)ViewBag.Settings;
}

@* --- RADİKAL YENİ HERO: STAGE DESIGN --- *@
<div class="hero-stage-section">
    <div class="container">
        <div class="row align-items-center g-5">
            @* SOL: Poster Görsel *@
            <div class="col-lg-6 order-2 order-lg-1 text-center">
                <div class="poster-frame">
                    <div class="poster-glow"></div>
                    <img src="@(set?.HeroImageUrl ?? "/images/ana-gorsel-saydam.png")" class="poster-img" alt="Emre Çakmakoğlu">
                </div>
            </div>

            @* SAĞ: Kimlik ve Duyurular *@
            <div class="col-lg-6 order-1 order-lg-2">
                <div class="identity-box">
                    <h1 class="main-name-title">Emre Çakmakoğlu</h1>
                    <div class="red-line"></div>
                    
                    <div class="glass-announcement-box">
                   
                        <div class="ann-scroll-area">
                            @await Component.InvokeAsync("Announcement")
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* --- MÜZİKLER (DİSKOGRAFİ) --- *@
<section id="muzikler" class="container">
    <div class="section-glass-panel">
        <h3 class="section-title">DİSKOGRAFİ</h3>
        <div class="row row-cols-2 row-cols-md-6 g-4 justify-content-center">
            @foreach (var item in Model) {
                <div class="col text-center">
                    <a href="@Url.Action("MusicDetail", "Home", new { id = item.Id })" class="text-decoration-none">
                        <div class="music-card mb-2"><img src="@item.ImageUrl" class="album-cover"></div>
                        <h6 class="text-white small fw-bold text-truncate">@item.Title</h6>
                        <small class="music-meta">@item.Year - @item.MusicType</small>
                    </a>
                </div>
            }
        </div>
        <div class="text-center mt-5">
            <a asp-action="Music" class="text-white-50 small letter-spacing-2 text-decoration-none hover-red">— TÜM ARŞİVİ İNCELE —</a>
        </div>
    </div>
</section>

@* --- KİTAP & BLOG --- *@
<section id="yazilar" class="container">
    <div class="section-glass-panel">
        <div class="row g-5">
            <div class="col-md-5 v-line text-center d-flex flex-column">
                <h3 class="section-title text-start mb-4">KİTAP</h3>
                @if (ViewBag.LatestBook != null) {
                    var book = (EmreCakmakoglu.Models.Book)ViewBag.LatestBook;
                    <div class="book-display-area">
                        <a href="@Url.Action("BookDetail", "Home", new { id = book.Id })" class="book-3d-wrapper">
                            <img src="@book.ImageUrl" class="img-fluid book-3d-main">
                        </a>
                        <h4 class="text-white playfair mt-4 mb-2">@book.Title</h4>
                        <p class="text-white-50 small px-4 mb-4">@Html.Raw(book.Subtitle)</p>
                        <a href="@Url.Action("BookDetail", "Home", new { id = book.Id })" class="btn btn-book-premium">ESERİ İNCELE</a>
                    </div>
                }
            </div>

            <div class="col-md-7">
                <h3 class="section-title mb-4">BLOG YAZILARI</h3>
                @foreach (var post in (IEnumerable<EmreCakmakoglu.Models.BlogPost>)ViewBag.Blogs) {
                    var isExternal = !string.IsNullOrEmpty(post.ExternalUrl);
                    var targetUrl = isExternal ? post.ExternalUrl : Url.Action("BlogDetail", "Home", new { id = post.Id });
                    <div class="blog-item-wrapper mb-3">
                        <a href="@targetUrl" target="@(isExternal ? "_blank" : "_self")" class="blog-horizontal-card text-decoration-none">
                            <div class="row g-0 align-items-center">
                                <div class="col-3">
                                    <img src="@post.ImageUrl" class="img-fluid rounded-start">
                                </div>
                                <div class="col-9 p-3">
                                    <h6 class="text-white mb-1 fw-bold">@post.Title</h6>
                                    <div class="blog-summary-new text-white-50 small">@Html.Raw(post.Summary)</div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@* --- MEDYA --- *@
<section id="medya" class="container mb-5">
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="section-glass-panel h-100">
                <h3 class="section-title mb-4">ÖNE ÇIKAN VİDEO</h3>
                <div class="ratio ratio-16x9 shadow-lg">
                    <iframe src="https://www.youtube.com/embed/@(set?.YoutubeVideoId ?? "VqnQmjfkr_4")" allowfullscreen></iframe>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="section-glass-panel h-100">
                <h3 class="section-title mb-4">SPOTIFY</h3>
                <iframe src="@(set?.SpotifyEmbedUrl ?? "")" width="100%" height="380" frameBorder="0" allow="autoplay; encrypted-media; fullscreen" style="border-radius:12px;"></iframe>
            </div>
        </div>
    </div>
</section>

<style>
    /* 1. GLOBAL DEĞİŞKENLER VE TEMEL AYARLAR */
    :root { 
        --e-red: #ff4d4d; 
        --glass-bg: rgba(255, 255, 255, 0.02);
        --glass-border: rgba(255, 255, 255, 0.05);
    }

    body { 
        color: #fff; 
        overflow-x: hidden; 
        /* Arka plan resmini ezmemek için buradaki background-color'ı kaldırdık */
    }

    /* 2. MODERN HERO STAGE */
/* 1. HERO ÜST BOŞLUĞUNU DARALTMA */
.hero-stage-section { 
    min-height: 75vh; 
    display: flex; 
    align-items: center; 
    padding-top: 60px; 
    padding-bottom: 10px; /* İşte sihirli dokunuş: Alttan 100px nefes payı verdik */
    height: auto; /* İçerik arttıkça boyu kısıtlamasın, otomatik uzasın */
    background: radial-gradient(circle at 15% 50%, rgba(255, 77, 77, 0.07) 0%, transparent 70%); 
    position: relative;
    z-index: 5; /* Diğer bölümlerin üstünde kalmasını garanti altına aldık */
}

    /* Sanatçı Görseli (Poster) */
    .poster-frame { position: relative; display: inline-block; z-index: 5; }
    .poster-img { 
        max-width: 100%; 
        height: auto; 
        max-height: 520px; 
        border-radius: 10px; 
        box-shadow: 0 30px 60px rgba(0,0,0,0.8); 
        position: relative; 
        z-index: 2; 
    }
    .poster-glow { 
        position: absolute; top: 50%; left: 50%; 
        transform: translate(-50%, -50%); width: 130%; height: 130%; 
        background: radial-gradient(circle, rgba(255, 77, 77, 0.1) 0%, transparent 70%); 
        z-index: 1; 
    }

    /* Kimlik Bilgileri */
.main-name-title { 
    font-family: 'Playfair Display', serif; 
    font-size: clamp(2.2rem, 5vw, 3.8rem); /* Fontu çok az küçülttük ki sığma şansı artsın */
    font-weight: 900; 
    margin-bottom: 5px; 
    color: #fff;
    white-space: nowrap; /* İSMİN ASLA ALT SATIRA KAYMAMASINI SAĞLAR */
}
    .red-line { width: 60px; height: 4px; background: var(--e-red); margin-bottom: 40px; }

    /* 3. GLASS DUYURU KUTUSU (Buzlu Cam Etkisi) */
/* GLASS ANNOUNCEMENT BOX (Güncellenmiş Şeffaflık) */
.glass-announcement-box {
    /* Rgba sondaki 0.3 değeri şeffaflığı belirler. 
       Daha şeffaf olsun istersen 0.2, daha koyu olsun istersen 0.5 yapabilirsin. */
    background: rgba(0, 0, 0, 0.3); 
    
    backdrop-filter: blur(20px); /* Arka planı buzlu cam gibi bulanıklaştırır */
    -webkit-backdrop-filter: blur(20px);
    
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 30px;
    box-shadow: 0 25px 50px rgba(0,0,0,0.4);
}
    .box-label { 
        font-size: 0.7rem; 
        font-weight: 800; 
        letter-spacing: 3px; 
        color: var(--e-red); 
        margin-bottom: 20px; 
        display: block; 
        opacity: 0.8; 
    }
    
    /* Duyuru Listesi Satırları */
    .ann-row { margin-bottom: 15px; padding-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .ann-row:last-child { border-bottom: none; margin-bottom: 0; }
    
    .ann-full-link { display: flex; align-items: flex-start; text-decoration: none !important; color: #fff !important; transition: 0.3s; }
    .ann-date { color: var(--e-red) !important; font-weight: 700; font-size: 0.85rem; min-width: 95px; font-family: monospace; }
    .ann-content { display: flex; flex-direction: column; padding-left: 10px; }
    .ann-title { font-size: 1rem; opacity: 0.95; line-height: 1.4; }
    .ann-sub { font-size: 0.8rem; color: rgba(255,255,255,0.4); font-style: italic; margin-top: 2px; }
    .ann-icon { margin-left: auto; color: var(--e-red); opacity: 0; transition: 0.3s; transform: translateX(-10px); }

    .ann-full-link:hover { transform: translateX(8px); }
    .ann-full-link:hover .ann-icon { opacity: 1; transform: translateX(0); }

    /* 4. DİĞER BÖLÜMLER (Müzik, Kitap, Blog) */
/* 2. DİSKOGRAFİ PANELİNİN ÜST MARJİNİNİ SIFIRLAMA */
.section-glass-panel { 
    background: var(--glass-bg); 
    backdrop-filter: blur(10px); 
    border: 1px solid var(--glass-border); 
    border-radius: 24px; 
    padding: 30px 40px;
    margin-top: 0 !important; /* Eğer negatif bir marjin (-30px gibi) varsa bunu sıfırladık */
    margin-bottom: 10px;
    position: relative;
    z-index: 10;
}
    .section-title { 
        font-family: 'Playfair Display', serif; 
        font-size: 1.4rem; 
        letter-spacing: 2px; 
        border-left: 3px solid var(--e-red); 
        padding-left: 15px; 
        margin-bottom: 30px; 
        color: #fff;
    }

    .music-card { border-radius: 12px; overflow: hidden; transition: 0.4s; }
    .music-card:hover { transform: translateY(-10px); box-shadow: 0 10px 20px rgba(0,0,0,0.5); }
    .album-cover { width: 100%; height: auto; }
    
    .blog-horizontal-card { 
        display: block; 
        background: rgba(255,255,255,0.01); 
        border: 1px solid var(--glass-border); 
        border-radius: 12px; 
        overflow: hidden; 
        transition: 0.3s; 
    }
    .blog-horizontal-card:hover { background: rgba(255,77,77,0.03); transform: translateX(5px); }

    /* 5. MOBİL AYARLAR */
    @@media (max-width: 991px) {
        .hero-stage-section { padding-top: 80px; text-align: center; }
        .red-line { margin: 15px auto 40px; }
        .ann-row { text-align: left; }
        .glass-announcement-box { padding: 20px; }
        .main-name-title { 
        white-space: normal; 
    }
    }
    
    .v-line { border-right: 1px solid var(--glass-border); }
    .hover-red:hover { color: var(--e-red) !important; transition: 0.3s; }
</style>