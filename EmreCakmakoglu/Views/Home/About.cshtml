@using EmreCakmakoglu.Data
@inject AppDbContext _context
@{
    var settings = _context.SiteSettings.FirstOrDefault();
    
    // Modelindeki "Title" sütununu kullanarak dinamik başlığı çekiyoruz
    var menuTitle = _context.Menus.FirstOrDefault(m => m.Url == "/Home/About")?.Title ?? "HAKKIMDA";
    ViewData["Title"] = menuTitle.ToUpper(); 
}

<div class="container internal-page-wrapper">
    
    @* STANDART BAŞLIK YAPISI *@
    <div class="text-center">
        <h1 class="page-standard-title">@ViewData["Title"]</h1>
        <div class="title-separator"></div>
    </div>

    <div class="row mt-5">
        @* FOTOĞRAF BÖLÜMÜ *@
        <div class="col-lg-5 col-md-12 mb-5">
            <div class="about-image-frame shadow-lg">
                <img src="@(settings?.AboutImageUrl ?? "/images/default-about.jpg")" 
                     class="img-fluid rounded-1" alt="Emre Çakmakoğlu">
            </div>
        </div>

        @* METİN BÖLÜMÜ (Arka Plan Ayarlı) *@
        <div class="col-lg-7 col-md-12 ps-lg-5">
            @* Okunabilirliği artıran, arka planı hafif karartan şeffaf panel *@
            <div class="about-text-glass-panel p-4 p-md-5">
                <h2 class="playfair mb-4 text-danger fw-bold fs-3">
                    @(settings?.AboutTitle ?? "Biyografi")
                </h2>
                <div class="about-content fw-light">
                    @Html.Raw(settings?.AboutText)
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* STANDART SAYFA DÜZENİ VE BOŞLUKLAR */
    .internal-page-wrapper {
        padding-top: 100px;
        padding-bottom: 80px;
    }

    .page-standard-title {
        font-family: 'Playfair Display', serif;
        font-size: 3.5rem;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: 2px;
        margin-bottom: 10px;
    }

    .title-separator {
        width: 60px;
        height: 3px;
        background-color: #8B261D;
        margin: 0 auto 20px auto;
    }

    /* METİN OKUNABİLİRLİĞİ İÇİN CAM PANEL (GLASSMORPISM) */
    .about-text-glass-panel {
        background: rgba(0, 0, 0, 0.25); /* Arka planı biraz daha kararttık */
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.3);
    }

    .about-content {
        line-height: 1.8;
        color: rgba(255,255,255,0.9); /* Okunabilirlik için yazı rengi %90 beyazlıkta */
        font-size: 1.1rem;
        text-align: justify;
    }

    /* FOTOĞRAF ÇERÇEVESİ */
    .about-image-frame {
        padding: 10px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 5px;
    }

    .playfair { font-family: 'Playfair Display', serif; }

    /* Mobil Cihazlar İçin Ayarlar */
    @@media (max-width: 991px) {
        .page-standard-title { font-size: 2.5rem; }
        .internal-page-wrapper { padding-top: 60px; }
        .about-text-glass-panel { padding: 25px !important; }
    }
</style>