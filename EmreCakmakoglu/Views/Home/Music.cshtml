@using EmreCakmakoglu.Data
@inject AppDbContext _context
@model IEnumerable<EmreCakmakoglu.Models.Music>
@{
    // Menü tablosundan dinamik başlığı çekiyoruz (Hakkımda'daki gibi)
    var menuTitle = _context.Menus.FirstOrDefault(m => m.Url == "/Home/Music")?.Title ?? "DİSKOGRAFİ";
    ViewData["Title"] = menuTitle.ToUpper(); 
}

<div class="container internal-page-wrapper">
    
    @* STANDART BAŞLIK YAPISI *@
    <div class="text-center">
        <h1 class="page-standard-title">@ViewData["Title"]</h1>
        <div class="title-separator"></div>
    </div>

    @* MÜZİK LİSTESİ PANELİ *@
    <div class="music-content-glass p-4 p-md-5 mt-5">
        <div class="row row-cols-2 row-cols-md-4 row-cols-lg-5 g-5 justify-content-center">
            @foreach (var item in Model)
            {
                <div class="col text-center">
                    <a href="@Url.Action("MusicDetail", "Home", new { id = item.Id })" class="music-link-item">
                        @* Albüm Kapak Alanı *@
                        <div class="album-container mb-3">
                            <div class="album-frame shadow-lg">
                                <img src="@item.ImageUrl" class="album-img" alt="@item.Title">
                                @* Üzerine gelince çıkan parıltı katmanı *@
                                <div class="album-overlay">
                                    <i class="bi bi-play-circle"></i>
                                </div>
                            </div>
                        </div>
                        
                        @* Metin Bilgileri *@
                        <div class="music-info">
                            <h6 class="text-white mb-1 fw-bold album-title playfair">@item.Title</h6>
                            <div class="d-flex justify-content-center align-items-center gap-2">
                                <span class="badge-year">@item.Year - @item.MusicType</span>
                                <span class="music-dot"></span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    /* STANDART SAYFA DÜZENİ VE BOŞLUKLAR */
    .internal-page-wrapper {
        padding-top: 100px;
        padding-bottom: 80px;
    }

    .page-standard-title {
        font-family: 'Playfair Display', serif;
        font-size: 3.5rem;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: 2px;
        margin-bottom: 10px;
    }

    .title-separator {
        width: 60px;
        height: 3px;
        background-color: #8B261D;
        margin: 0 auto 20px auto;
    }

    /* OKUNABİLİRLİK İÇİN İÇERİK PANELİ */
    .music-content-glass {
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 30px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
    }

    .music-link-item { text-decoration: none !important; display: block; }

    /* ALBÜM KAPAK TASARIMI */
    .album-frame {
        position: relative;
        aspect-ratio: 1/1;
        overflow: hidden;
        border-radius: 12px;
        background: #1a1a1a;
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .album-img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }

    /* HOVER EFEKTLERİ */
    .music-link-item:hover .album-frame {
        transform: translateY(-10px);
        border-color: #8B261D;
        box-shadow: 0 15px 30px rgba(139, 38, 29, 0.4);
    }

    .music-link-item:hover .album-img { transform: scale(1.1); filter: brightness(0.5); }

    .album-overlay {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        display: flex; align-items: center; justify-content: center;
        opacity: 0; transition: 0.3s;
    }

    .album-overlay i { color: #ffffff; font-size: 2.5rem; }
    .music-link-item:hover .album-overlay { opacity: 1; }

    /* METİN STİLLERİ */
    .album-title { font-size: 1rem; transition: 0.3s; letter-spacing: 0.5px; }
    .music-link-item:hover .album-title { color: #ff4d4d !important; }

    .badge-year {
        font-size: 0.7rem;
        background: rgba(255, 255, 255, 0.05);
        padding: 2px 8px;
        border-radius: 4px;
        color: rgba(255,255,255,0.6);
    }

    .music-dot { width: 4px; height: 4px; background: #8B261D; border-radius: 50%; }
    .playfair { font-family: 'Playfair Display', serif; }

    @@media (max-width: 768px) {
        .page-standard-title { font-size: 2.5rem; }
        .internal-page-wrapper { padding-top: 60px; }
    }
</style>