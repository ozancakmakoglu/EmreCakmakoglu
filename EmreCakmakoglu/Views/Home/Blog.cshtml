@using EmreCakmakoglu.Data
@inject AppDbContext _context
@model IEnumerable<EmreCakmakoglu.Models.BlogPost>
@{
    // Menü tablosundan başlığı dinamik çekiyoruz
    var menuTitle = _context.Menus.FirstOrDefault(m => m.Url == "/Home/Blog")?.Title ?? "BLOG";
    ViewData["Title"] = menuTitle.ToUpper(); 
}

<div class="container internal-page-wrapper">
    
    @* STANDART BAŞLIK YAPISI *@
    <div class="text-center">
        <h1 class="page-standard-title">@ViewData["Title"]</h1>
        <div class="title-separator"></div>
    </div>

    @* BLOG LİSTESİ PANELİ *@
    <div class="blog-archive-glass p-4 p-md-5 mt-5 shadow-lg">
        @foreach (var post in Model)
        {
            var isExternal = !string.IsNullOrEmpty(post.ExternalUrl);
            var targetUrl = isExternal ? post.ExternalUrl : Url.Action("BlogDetail", "Home", new { id = post.Id });

            <div class="archive-blog-item mb-5">
                <a href="@targetUrl" target="@(isExternal ? "_blank" : "_self")" class="row g-4 text-decoration-none">
                    @* Görsel Alanı *@
                    <div class="col-md-3">
                        <div class="archive-img-frame">
                            <img src="@post.ImageUrl" class="img-fluid" alt="@post.Title">
                            @if (isExternal)
                            {
                                <div class="external-badge">
                                    <i class="bi bi-link-45deg"></i>
                                </div>
                            }
                        </div>
                    </div>

                    @* İçerik Alanı *@
                    <div class="col-md-9">
                        <div class="archive-content-box">
                            <small class="text-danger fw-bold letter-spacing-2">
                                @post.CreatedDate.ToString("dd MMMM yyyy").ToUpper()
                            </small>
                            
                            <h4 class="archive-title text-white mt-2 mb-3 playfair">
                                @post.Title
                            </h4>
                            
                            @* HTML ETİKETLERİNDEN ARINDIRILMIŞ ÖZET *@
                            <p class="archive-summary">
                                @{
                                    // Önce HTML etiketlerini (p, br, strong vb.) tamamen siliyoruz
                                    var rawSummary = post.Summary ?? "";
                                    var cleanSummary = System.Text.RegularExpressions.Regex.Replace(rawSummary, "<.*?>", String.Empty);

                                    if (cleanSummary.Length > 500) {
                                        @cleanSummary.Substring(0, 500) <text>...</text>
                                    } else {
                                        @cleanSummary
                                    }
                                }
                            </p>

                            <div class="archive-footer mt-3">
                                <span class="read-more-link">
                                    @(isExternal ? "TAMAMINI OKU" : "TAMAMINI OKU") 
                                    <i class="bi bi-arrow-right ms-2"></i>
                                </span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<style>
    /* STANDART SAYFA DÜZENİ */
    .internal-page-wrapper {
        padding-top: 100px;
        padding-bottom: 80px;
    }

    .page-standard-title {
        font-family: 'Playfair Display', serif;
        font-size: 3.5rem;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: 2px;
        margin-bottom: 10px;
    }

    .title-separator {
        width: 60px;
        height: 3px;
        background-color: #8B261D;
        margin: 0 auto 20px auto;
    }

    /* BLOG PANELİ (GLASS) */
    .blog-archive-glass {
        background: rgba(0, 0, 0, 0.25);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 20px;
    }

    .archive-blog-item {
        transition: all 0.4s ease;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding-bottom: 2rem;
    }

    .archive-blog-item:last-child { border-bottom: none; }

    .archive-img-frame {
        position: relative;
        overflow: hidden;
        border-radius: 12px;
        aspect-ratio: 1 / 1;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .archive-img-frame img { width: 100%; height: 100%; object-fit: cover; transition: 0.5s; }

    .external-badge {
        position: absolute; top: 10px; right: 10px; background: #8B261D;
        color: white; width: 30px; height: 30px; display: flex;
        align-items: center; justify-content: center; border-radius: 50%;
    }

    .archive-title { font-size: 1.6rem; transition: 0.3s; }
    .playfair { font-family: 'Playfair Display', serif; }

    .archive-summary {
        font-size: 1rem;
        color: rgba(255,255,255,0.8);
        line-height: 1.7;
        text-align: justify;
    }

    .read-more-link {
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 2px;
        color: #ff4d4d;
        transition: 0.3s;
    }

    .archive-blog-item:hover .archive-title { color: #ff4d4d !important; }
    .archive-blog-item:hover { background: rgba(255,255,255,0.02); }

    .letter-spacing-2 { letter-spacing: 2px; }

    @@media (max-width: 768px) {
        .page-standard-title { font-size: 2.5rem; }
        .archive-img-frame { aspect-ratio: 16 / 9; margin-bottom: 15px; }
    }
</style>