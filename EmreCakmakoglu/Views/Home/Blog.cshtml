@model IEnumerable<EmreCakmakoglu.Models.BlogPost>
<div class="container" style="margin-top: 120px;">
    <div class="row justify-content-center">
        <div class="col-lg-10 section-glass-panel">
            <h3 class="section-title">BLOG YAZILARIM</h3>
            @foreach (var post in Model)
            {
                <div class="blog-item py-4 border-bottom border-secondary border-opacity-10">
                    <a href="@Url.Action("BlogDetail", "Home", new { id = post.Id })" class="row align-items-center g-4">
                        <div class="col-md-2"><img src="@post.ImageUrl" class="img-fluid rounded-1 shadow"></div>
                        <div class="col-md-10">
                            <h4 class="text-white mb-2 fw-normal fs-5">@post.Title</h4>
                            <small class="text-danger opacity-75">@post.CreatedDate.ToString("dd MMMM yyyy")</small>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</div>