@model EmreCakmakoglu.Models.Music
@{
    ViewData["Title"] = Model.Title;
}

<div class="container music-detail-container pb-5" style="margin-top: 100px;">
    
    @* Üst Başlık Bölümü *@
    <div class="row mb-5 justify-content-center text-center">
        <div class="col-12">
            <h1 class="display-4 fw-bold main-title text-white">@Model.Title</h1>
            <p class="text-muted fs-5 italic">@Model.Year — Single/Albüm</p>
        </div>
    </div>

    @* Ana İçerik: align-items-start ile görseli yukarı sabitledik *@
    <div class="row g-5 align-items-start justify-content-center">
        
        @* SOL: Şarkı Görseli *@
        <div class="col-md-4 d-flex justify-content-center justify-content-md-end">
            <div class="album-cover-wrapper shadow-lg p-1" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 5px;">
                <img src="@Model.ImageUrl" class="img-fluid" alt="@Model.Title" style="max-width: 350px; width: 100%; border-radius: 4px;">
            </div>
        </div>

        @* SAĞ: Şarkı Sözleri Paneli *@
        <div class="col-md-7 col-lg-6">
            <div class="lyrics-panel p-4" style="background: rgba(0,0,0,0.3); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.05); border-left: 4px solid #8B261D;">
                
                <h6 class="text-uppercase text-secondary small mb-4 letter-spacing-2" style="letter-spacing: 2px;">Şarkı Hakkında / Sözler</h6>

                <div class="lyrics-text text-white-50" style="white-space: pre-line; line-height: 1.8; font-size: 1.1rem; italic">
                    @Html.Raw(Model.Description)
                </div>
            </div>

            @* Butonlar *@
            <div class="mt-5 d-flex gap-3 justify-content-center justify-content-md-start">
                @if (!string.IsNullOrEmpty(Model.SpotifyUrl))
                {
                    <a href="@Model.SpotifyUrl" target="_blank" class="btn btn-custom-red px-4 py-2">
                        Spotify'da Dinle
                    </a>
                }
                <a href="/" class="btn btn-custom-outline px-4 py-2 text-white">Ana Sayfa'ya Dön</a>
            </div>
        </div>
    </div>
</div>